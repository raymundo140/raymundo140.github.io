---
interface Props {
  base?: string
  count: number
}

const { base = '', count } = Astro.props
const href = base ? `${base}/projects` : '/projects'
---

<a href={href} class="card bg-base-200 border border-base-300 text-base-content shadow-sm hover:shadow-md hover:border-base-400 transition-all duration-200 cursor-pointer group">
  <div class="card-body items-center justify-center text-center gap-3 min-h-[260px]">
    <span class="text-5xl group-hover:scale-110 transition-transform duration-200">🗂️</span>
    <h3 class="card-title text-lg font-bold">All Projects</h3>
    <p class="text-sm text-base-content/60">See all {count} projects with full details</p>
    <span class="mt-2 text-sm font-semibold underline underline-offset-2">View all →</span>
  </div>
</a>