---
import type { Award } from '@/settings'
interface Props {
  item: Award
}
const { item } = Astro.props
const { title, issuer, location, date, description, bullets, link, logo } = item
const hasBullets = bullets && bullets.length > 0
---


  href={link}
  target='_blank'
  rel='noopener noreferrer'
  class='block bg-base-200 border border-base-300 rounded-2xl p-6 hover:shadow-md hover:border-base-content/80 transition-all duration-200 group cursor-pointer no-underline'
>
  <div class='flex items-start gap-5'>
    <div class='shrink-0 w-14 h-14 rounded-xl border border-base-300 bg-base-100 overflow-hidden flex items-center justify-center'>
      <img
        src={logo}
        alt={issuer}
        class='w-full h-full object-contain p-1'
        onerror="this.style.display='none'"
      />
    </div>
    <div class='flex flex-col gap-2 flex-1 min-w-0'>
      <div class='flex items-start justify-between gap-4 flex-wrap'>
        <div>
          <h3 class='font-bold text-base group-hover:font-extrabold transition-all leading-snug'>
            🏆 {title}
          </h3>
          <p class='text-sm text-base-content/60'>{issuer}</p>
        </div>
        <div class='text-right shrink-0'>
          <span class='text-sm font-medium text-base-content/70'>{date}</span>
          <p class='text-xs text-base-content/50'>{location}</p>
        </div>
      </div>
      <p class='text-sm text-base-content/75'>{description}</p>
      {hasBullets && bullets.map(b => (
        <div class='flex gap-2 items-baseline text-sm text-base-content/70'>
          <span class='text-base-content/60 shrink-0'>▸</span>
          <span>{b}</span>
        </div>
      ))}
      <div class='mt-2 text-sm font-semibold text-base-content/60'>View on LinkedIn ↗</div>
    </div>
  </div>
</a>