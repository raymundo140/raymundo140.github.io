---
import type { Education } from '@/settings'

interface Props {
  item: Education
  base?: string
}

const { item, base = '' } = Astro.props
const { slug, institution, program, field, location, dateRange, grade, tags, logo } = item
const href = base + '/education/' + slug
---

<a href={href} class="block bg-base-200 border border-base-300 rounded-2xl p-6 hover:shadow-md hover:border-primary transition-all duration-200 group cursor-pointer no-underline">
  <div class="flex items-start gap-5">

    <div class="shrink-0 w-14 h-14 rounded-xl border border-base-300 bg-base-100 overflow-hidden flex items-center justify-center">
      <img
        src={logo}
        alt={institution}
        class="w-full h-full object-contain p-1"
        onerror="this.style.display='none'"
      />
    </div>

    <div class="flex flex-col gap-2 flex-1 min-w-0">

      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h3 class="font-bold text-base group-hover:text-primary transition-colors leading-snug">
            {institution}
          </h3>
          <p class="text-sm text-base-content/70 font-medium">{program}</p>
          <p class="text-sm text-base-content/60">{field}</p>
        </div>
        <div class="text-right shrink-0">
          <span class="text-sm font-medium text-base-content/70">{dateRange}</span>
          <p class="text-xs text-base-content/50">{location}</p>
          <p class="text-xs font-semibold text-primary mt-1">{grade}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-1 mt-1">
        {tags.map(tag => (
          <span class="badge badge-outline badge-sm">{tag}</span>
        ))}
      </div>

      <div class="mt-2 text-sm font-semibold text-primary">View details →</div>
    </div>

  </div>
</a>