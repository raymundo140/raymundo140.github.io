---
import type { Project } from '@/settings'

interface Props {
  project: Project
  base?: string
}

const { project, base = '' } = Astro.props
const { slug, title, summary, tags, image, institution, company, location, logo } = project
const href = `${base}/projects/${slug}`
const displayName = company ? company : institution
---

<a href={href} class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-base-content/80 transition-all duration-200 group cursor-pointer no-underline">

  <div class="relative h-40 overflow-hidden rounded-t-2xl bg-base-300 flex items-center justify-center">
    <img
      src={image}
      alt=""
      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      onerror="this.style.display='none'"
    />
    <span class="text-4xl opacity-30 select-none">🤖</span>
  </div>

  <div class="card-body p-4 gap-2">

    {(displayName || location) && (
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded overflow-hidden border border-base-300 bg-base-200 shrink-0 flex items-center justify-center">
          <img
            src={logo}
            alt={displayName}
            class="w-full h-full object-contain"
            onerror="this.style.display='none'"
          />
        </div>
        <div class="flex flex-col">
          <p class="text-xs font-semibold text-base-content/80">{displayName}</p>
          {location && <p class="text-xs text-base-content/40">{location}</p>}
        </div>
      </div>
    )}

    <h3 class="card-title text-base font-semibold leading-snug group-hover:font-bold transition-all">
      {title}
    </h3>

    <p class="text-sm text-base-content/70 line-clamp-3">{summary}</p>

    <div class="flex flex-wrap gap-1 mt-1">
      {tags.map((tag) => (
        <span class="badge badge-outline badge-sm">{tag}</span>
      ))}
    </div>

  </div>

</a>