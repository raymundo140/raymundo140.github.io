---
import Layout from "../layouts/Layout.astro";

const pdfPath = `${import.meta.env.BASE_URL}cv/Raymundo_CV.pdf`;
---

<Layout title="CV | Raymundo">
  <section class="space-y-4">
    <h1 class="text-3xl font-black">CV</h1>

    <div class="flex gap-3 flex-wrap">
      <a class="btn btn-primary" href={pdfPath} target="_blank" rel="noopener">
        Open in new tab (zoom)
      </a>

      <a class="btn btn-outline" href={pdfPath} download>
        Download PDF
      </a>
    </div>

    <div class="w-full rounded-xl overflow-hidden border border-base-200">
      <iframe
        title="Raymundo CV"
        src={`${pdfPath}#view=FitH`}
        class="w-full"
        style="height: 130vh;"
      ></iframe>
    </div>

    <p class="text-sm opacity-70">
      Tip: “Open in new tab” gives the best zoom/search experience.
    </p>
  </section>
</Layout>