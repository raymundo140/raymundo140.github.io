---
import Layout from '../layouts/Layout.astro'
import { education, template } from '@/settings'

const base = template.base
---

<Layout>
  <div class='max-w-4xl mx-auto py-12'>

    <div class='mb-12 border-b pb-8'>
      <h1 class='text-4xl font-bold mb-3'>Education</h1>
      <p class='text-base-content/70 text-lg'>
        Academic background across international institutions in robotics, AI, and engineering.
      </p>
    </div>

    <div class='flex flex-col gap-4'>
      {education.map(item => {
        const href = base + '/education/' + item.slug
        return (
          <a href={href} class='block bg-base-200 border border-base-300 rounded-2xl p-6 hover:shadow-md hover:border-primary transition-all duration-200 group cursor-pointer no-underline'>
            <div class='flex items-start gap-5'>
              <div class='shrink-0 w-14 h-14 rounded-xl border border-base-300 bg-base-100 overflow-hidden flex items-center justify-center'>
                <img src={item.logo} alt={item.institution} class='w-full h-full object-contain p-1' onerror="this.style.display='none'" />
              </div>
              <div class='flex flex-col gap-2 flex-1 min-w-0'>
                <div class='flex items-start justify-between gap-4 flex-wrap'>
                  <div>
                    <h3 class='font-bold text-base group-hover:text-primary transition-colors leading-snug'>{item.institution}</h3>
                    <p class='text-sm text-base-content/70 font-medium'>{item.program}</p>
                    <p class='text-sm text-base-content/60'>{item.field}</p>
                  </div>
                  <div class='text-right shrink-0'>
                    <span class='text-sm font-medium text-base-content/70'>{item.dateRange}</span>
                    <p class='text-xs text-base-content/50'>{item.location}</p>
                    <p class='text-xs font-semibold text-primary mt-1'>{item.grade}</p>
                  </div>
                </div>
                <div class='flex flex-wrap gap-1 mt-1'>
                  {item.tags.map(tag => <span class='badge badge-outline badge-sm'>{tag}</span>)}
                </div>
                <div class='mt-2 text-sm font-semibold text-primary'>View details →</div>
              </div>
            </div>
          </a>
        )
      })}
    </div>

  </div>
</Layout>