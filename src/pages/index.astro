---
import Layout from '../layouts/Layout.astro'
import { profile, projects, experiences, research, education, awards, skillCategories, languages, template } from '@/settings'
import ProfilePictures from '@/assets/profile_pictures.jpg'
import Hero from '@/components/ui/Hero.astro'
import ProjectCard from '@/components/ui/ProjectCard.astro'
import AllProjectsCard from '@/components/ui/AllProjectsCard.astro'
import ExperienceCard from '@/components/ui/ExperienceCard.astro'
import ResearchCard from '@/components/ui/ResearchCard.astro'
import EducationCard from '@/components/ui/EducationCard.astro'

const { fullName, title, institute } = profile
const base = template.base
const previewProjects = projects.slice(0, 5)
---

<Layout>
  <section class='flex items-center gap-12 border-b pb-12'>
    <Hero fullName={fullName} title={title} institute={institute} profilePicture={ProfilePictures} />
  </section>

  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Projects</h2>
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5'>
      {previewProjects.map(project => (
        <ProjectCard project={project} base={base} />
      ))}
      <AllProjectsCard base={base} count={projects.length} />
    </div>
  </section>

  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Work Experience</h2>
    <div class='flex flex-col gap-4'>
      {experiences.map(exp => (
        <ExperienceCard experience={exp} base={base} />
      ))}
    </div>
  </section>

  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Research & Invited Talks</h2>
    <div class='flex flex-col gap-4'>
      {research.map(item => (
        <ResearchCard item={item} base={base} />
      ))}
    </div>
  </section>

  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Education</h2>
    <div class='flex flex-col gap-4'>
      {education.map(item => (
        <EducationCard item={item} base={base} />
      ))}
    </div>
  </section>

  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Awards & Recognition</h2>
    <div class='flex flex-col gap-4'>
      {awards.map(a => {
        const bullets = a.bullets || []
        return (
          <a href={a.link} target='_blank' rel='noopener noreferrer'
            class='block bg-base-200 border border-base-300 rounded-2xl p-6 hover:shadow-md hover:border-primary transition-all duration-200 group cursor-pointer no-underline'>
            <div class='flex items-start gap-5'>
              <div class='shrink-0 w-14 h-14 rounded-xl border border-base-300 bg-base-100 overflow-hidden flex items-center justify-center'>
                <img src={a.logo} alt={a.issuer} class='w-full h-full object-contain p-1' onerror="this.style.display='none'" />
              </div>
              <div class='flex flex-col gap-2 flex-1 min-w-0'>
                <div class='flex items-start justify-between gap-4 flex-wrap'>
                  <div>
                    <h3 class='font-bold text-base group-hover:text-primary transition-colors'>🏆 {a.title}</h3>
                    <p class='text-sm text-base-content/60'>{a.issuer}</p>
                  </div>
                  <div class='text-right shrink-0'>
                    <span class='text-sm font-medium text-base-content/70'>{a.date}</span>
                    <p class='text-xs text-base-content/50'>{a.location}</p>
                  </div>
                </div>
                <p class='text-sm text-base-content/75'>{a.description}</p>
                {bullets.map(b => {
                  return <div class='flex gap-2 text-sm text-base-content/70'>
                    <span class='text-primary shrink-0'>▸</span>
                    <span>{b}</span>
                  </div>
                })}
                <div class='mt-2 text-sm font-semibold text-primary'>View on LinkedIn ↗</div>
              </div>
            </div>
          </a>
        )
      })}
    </div>
  </section>

  <section class='py-12'>
    <h2 class='text-2xl font-bold mb-8'>Skills</h2>

    <!-- Languages -->
    <div class='bg-base-200 border border-base-300 rounded-2xl p-6 mb-4'>
      <div class='flex items-center gap-2 mb-4'>
        <span class='text-xl'>🌐</span>
        <h2 class='text-lg font-bold'>Languages</h2>
      </div>
      <div class='grid grid-cols-2 md:grid-cols-4 gap-4'>
        {languages.map(lang => {
          return (
            <div class='bg-base-100 border border-base-300 rounded-xl p-4 flex flex-col gap-1'>
              <p class='font-bold text-base'>{lang.name}</p>
              <p class='text-primary font-semibold text-sm'>{lang.level}</p>
              <p class='text-base-content/50 text-xs'>{lang.note}</p>
            </div>
          )
        })}
      </div>
    </div>

    <!-- Skill categories -->
    <div class='flex flex-col gap-4'>
      {skillCategories.map(cat => {
        return (
          <div class='bg-base-200 border border-base-300 rounded-2xl p-6'>
            <div class='flex items-center gap-2 mb-4'>
              <span class='text-xl'>{cat.icon}</span>
              <h2 class='text-lg font-bold'>{cat.category}</h2>
            </div>
            <div class='flex flex-wrap gap-2'>
              {cat.skills.map(skill => {
                return <span class='px-3 py-1 bg-base-100 border border-base-300 rounded-full text-sm text-base-content/80'>{skill}</span>
              })}
            </div>
          </div>
        )
      })}
    </div>

  </section>
</Layout>