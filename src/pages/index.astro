---
import Layout from '../layouts/Layout.astro'
import { profile, projects, experiences, template } from '@/settings'
import { publications } from '@/data/cv'
import ProfilePictures from '@/assets/profile_pictures.jpg'
import Hero from '@/components/ui/Hero.astro'
import ArticleList from '@/components/ui/ArticleList.astro'
import ProjectCard from '@/components/ui/ProjectCard.astro'
import AllProjectsCard from '@/components/ui/AllProjectsCard.astro'
import ExperienceCard from '@/components/ui/ExperienceCard.astro'

const { fullName, title, institute } = profile
const base = template.base
const previewProjects = projects.slice(0, 5)
---

<Layout>
  <!-- Hero -->
  <section class='flex items-center gap-12 border-b pb-12'>
    <Hero fullName={fullName} title={title} institute={institute} profilePicture={ProfilePictures} />
  </section>

  <!-- Projects -->
  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Projects</h2>
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5'>
      {previewProjects.map(project => (
        <ProjectCard project={project} base={base} />
      ))}
      <AllProjectsCard base={base} count={projects.length} />
    </div>
  </section>

  <!-- Work Experience -->
  <section class='py-12 border-b'>
    <h2 class='text-2xl font-bold mb-8'>Work Experience</h2>
    <div class='flex flex-col gap-4'>
      {experiences.map(exp => (
        <ExperienceCard experience={exp} base={base} />
      ))}
    </div>
  </section>

  <!-- Research -->
  <section class='py-12 border-t'>
    <ArticleList listTitle='Research' listItems={publications} />
  </section>

  <!-- Education -->
  <section class='py-12 border-t'>
    <ArticleList listTitle='Education' listItems={publications} />
  </section>
</Layout>