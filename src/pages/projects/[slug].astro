---
import Layout from '../../layouts/Layout.astro'
import { projects, template } from '@/settings'

export async function getStaticPaths() {
  const { projects } = await import('@/settings')
  return projects.map(p => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const base = template.base

const project = projects.find(p => p.slug === slug)

if (!project) {
  return Astro.redirect(base + '/projects')
}

const description = project.description || project.summary
---

<Layout>
  <div class='max-w-4xl mx-auto py-12'>

    <a href={base + '/projects'} class='btn btn-ghost btn-sm mb-8 -ml-2'>
      ← Back to Projects
    </a>

    <div class='mb-10'>
      <h1 class='text-4xl font-bold mb-4'>{project.title}</h1>
      <div class='flex flex-wrap gap-2 mb-6'>
        {project.tags.map(tag => <span class='badge badge-outline'>{tag}</span>)}
      </div>
      <div class='flex gap-3 flex-wrap'>
        {project.repoUrl && (
          <a href={project.repoUrl} target='_blank' rel='noopener noreferrer' class='btn btn-sm btn-outline gap-2'>
            <svg xmlns='http://www.w3.org/2000/svg' class='h-4 w-4' viewBox='0 0 24 24' fill='currentColor'>
              <path d='M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.55v-1.93c-3.19.69-3.86-1.54-3.86-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.74 2.67 1.24 3.32.95.1-.74.4-1.24.72-1.53-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 2.87-.39c.97.01 1.95.13 2.87.39 2.18-1.49 3.14-1.18 3.14-1.18.63 1.57.23 2.73.11 3.02.74.8 1.18 1.82 1.18 3.07 0 4.41-2.69 5.38-5.25 5.66.41.36.78 1.07.78 2.15v3.19c0 .3.2.66.79.55C20.21 21.37 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z'/>
            </svg>
            GitHub
          </a>
        )}
        {project.demoUrl && (
          <a href={project.demoUrl} target='_blank' rel='noopener noreferrer' class='btn btn-sm btn-primary gap-2'>
            Live Demo →
          </a>
        )}
      </div>
    </div>

    <div class='rounded-2xl overflow-hidden border border-base-300 aspect-video bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center relative mb-10'>
      <img
        src={project.image}
        alt={project.title}
        class='absolute inset-0 w-full h-full object-cover'
        onerror="this.style.display='none'"
      />
      <span class='text-7xl opacity-20 select-none'>🤖</span>
    </div>

    <div class='prose max-w-none'>
      <p>{description}</p>
      <div class='mt-12 p-6 border-2 border-dashed border-base-300 rounded-xl text-center text-base-content/40'>
        <p class='text-lg'>📄 Full project documentation coming soon.</p>
        <p class='text-sm mt-1'>Add your details to the <code>description</code> field in <code>settings.ts</code>.</p>
      </div>
    </div>

  </div>
</Layout>