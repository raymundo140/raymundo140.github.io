---
import Layout from '../layouts/Layout.astro'
import { skillCategories, languages } from '@/settings'
---

<Layout>
  <div class='max-w-5xl mx-auto py-12'>

    <div class='mb-12 border-b pb-8'>
      <h1 class='text-4xl font-bold mb-3'>Skills</h1>
      <p class='text-base-content/70 text-lg'>
        Technical skills, tools, and languages developed across academic and professional experience.
      </p>
    </div>

    <!-- Languages -->
    <div class='bg-base-200 border border-base-300 rounded-2xl p-6 mb-6'>
      <div class='flex items-center gap-2 mb-4'>
        <span class='text-2xl'>🌐</span>
        <h2 class='text-lg font-bold'>Languages</h2>
      </div>
      <div class='grid grid-cols-2 md:grid-cols-4 gap-4'>
        {languages.map(lang => {
          return (
            <div class='bg-base-100 border border-base-300 rounded-xl p-4 flex flex-col gap-1'>
              <p class='font-bold text-base'>{lang.name}</p>
              <p class='text-base-content/60 font-semibold text-sm'>{lang.level}</p>
              <p class='text-base-content/50 text-xs'>{lang.note}</p>
            </div>
          )
        })}
      </div>
    </div>

    <!-- Skill categories -->
    <div class='flex flex-col gap-4'>
      {skillCategories.map(cat => {
        return (
          <div class='bg-base-200 border border-base-300 rounded-2xl p-6'>
            <div class='flex items-center gap-2 mb-4'>
              <span class='text-xl'>{cat.icon}</span>
              <h2 class='text-lg font-bold'>{cat.category}</h2>
            </div>
            <div class='flex flex-wrap gap-2'>
              {cat.skills.map(skill => {
                return <span class='px-3 py-1 bg-base-100 border border-base-300 rounded-full text-sm text-base-content/80'>{skill}</span>
              })}
            </div>
          </div>
        )
      })}
    </div>

  </div>
</Layout>